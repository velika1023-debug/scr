# Requset N1B0 Project - 241031
ifdef sdc_ver
    SDC_VER = $(sdc_ver)
endif

COMMON_CON_DIR      = $(OUTFD_DIR)/common/$(COMMON_CON_VERSION)

IMPL_SDC_DIR        = $(OUTFD_DIR)/$(DESIGN)/$(INDB_VER)/impl_sdc/$(SDC_VER)
PNR_SDC_DIR         = $(OUTFD_DIR)/$(DESIGN)/$(INDB_VER)/pnrin/$(PNRIN_NET_REVISION)/sdc

ifeq ($(is_etm),1)
    is_flat=1
endif
ifeq ($(is_hsc),1)
    is_flat=1
endif

ifeq ($(is_flat),1)
    ifeq ($(HIER_DESIGN),NONE)
        READ_DESIGN = $(DESIGN)
    else
        READ_DESIGN = $(DESIGN) $(HIER_DESIGN)
    endif
else
    READ_DESIGN = $(DESIGN)
endif

