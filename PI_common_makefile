define define__READ_DESIGN_INFO
    @for i in $(READ_DESIGN); do                                                      \
        design=$$i                                                                   ;\
        SUB_INDB_VER=$$(projconf.pl           -get $${design}_INDB_VER )             ;\
        SUB_SDC_VER=$$(projconf.pl            -get $${design}_SDC_VER )              ;\
        SUB_NET_REVISION_SYN=$$(projconf.pl   -get PRE_$${design}_REVISION_SYN)      ;\
        SUB_NET_REVISION_BIST=$$(projconf.pl  -get PRE_$${design}_REVISION_BIST)     ;\
        SUB_NET_REVISION_SCAN=$$(projconf.pl  -get PRE_$${design}_REVISION_SCAN)     ;\
        SUB_NET_REVISION_PNRIN=$$(projconf.pl -get PRE_$${design}_REVISION_PNRIN)    ;\
        SUB_PNR_TOOL=$$(projconf.pl           -get $${design}_PNR_TOOL)              ;\
        SUB_DK_TYPE=$$(projconf.pl            -get $${design}_DK_TYPE)               ;\
        SUB_TRACK=$$(projconf.pl              -get $${design}_TRACK)                 ;\
        SUB_NET_REVISION_POST=$$(projconf.pl  -get POST_$${design}_REVISION)         ;\
        SUB_NET_ECO_NUM=$$(projconf.pl        -get POST_$${design}_ECO_NUM)          ;\
        SUB_ABS_MEM_VERSION=$$(projconf.pl    -get $${design}_ABS_MEM_VERSION)       ;\
        SUB_ABS_IP_VERSION=$$(projconf.pl     -get $${design}_ABS_IP_VERSION)        ;\
        SUB_SYN_TOOL=$$(projconf.pl           -get $${design}_SYN_TOOL)              ;\
        SUB_BIST_TOOL=$$(projconf.pl          -get $${design}_BIST_TOOL)             ;\
        SUB_SCAN_TOOL=$$(projconf.pl          -get $${design}_SCAN_TOOL)             ;\
        SUB_STA_TOOL=$$(projconf.pl           -get $${design}_STA_TOOL)              ;\
        echo ""                                                                                                              ;\
        echo "#== $$design == Information"                                                                                   ;\
        echo "set $$design(NAME)               \"$$design\""                                                                 ;\
        echo "set $$design(INDB_VER)           \"$$SUB_INDB_VER\""                                                           ;\
        echo "set $$design(SYN_TOOL)           \"$$SUB_SYN_TOOL\""                                                           ;\
        echo "set $$design(BIST_TOOL)          \"$$SUB_BIST_TOOL\""                                                          ;\
        echo "set $$design(SCAN_TOOL)          \"$$SUB_SCAN_TOOL\""                                                          ;\
        echo "set $$design(STA_TOOL)           \"$$SUB_STA_TOOL\""                                                           ;\
        echo "set $$design(TRACK)              \"$$SUB_TRACK\""                                                              ;\
        echo "set $$design(DK_TYPE)            \"$$SUB_DK_TYPE\""                                                            ;\
        echo "set $$design(ABS_MEM_VERSION)    \"$$SUB_ABS_MEM_VERSION\""                                                    ;\
        echo "set $$design(ABS_IP_VERSION)     \"$$SUB_ABS_IP_VERSION\""                                                     ;\
        echo "set $$design(SDC_VER)            \"$$SUB_SDC_VER\""                                                            ;\
        echo "set $$design(IMPL_SDC_DIR)       \"$(OUTFD_DIR)/$$design/$$SUB_INDB_VER/impl_sdc/$$SUB_SDC_VER\""              ;\
        echo "set $$design(PNR_SDC_DIR)        \"$(OUTFD_DIR)/$$design/$$SUB_INDB_VER/pnrin/$$SUB_NET_REVISION_PNRIN/sdc\""  ;\
        echo ""                                                                                                              ;\
        echo "set $$design(NET_REVISION_SYN)   \"$$SUB_NET_REVISION_SYN\""                                                   ;\
        echo "set $$design(NET_REVISION_BIST)  \"$$SUB_NET_REVISION_BIST\""                                                  ;\
        echo "set $$design(NET_REVISION_SCAN)  \"$$SUB_NET_REVISION_SCAN\""                                                  ;\
        echo "set $$design(NET_REVISION_PNRIN) \"$$SUB_NET_REVISION_PNRIN\""                                                 ;\
        echo ""                                                                                                              ;\
        echo "set $$design(PNR_TOOL)           \"$$SUB_PNR_TOOL\""                                                           ;\
        echo "set $$design(NET_REVISION_POST)  \"$$SUB_NET_REVISION_POST\""                                                  ;\
        echo "set $$design(NET_ECO_NUM)        \"$$SUB_NET_ECO_NUM\""                                                        ;\
        echo ""                                                                                                              ;\
    done
endef
