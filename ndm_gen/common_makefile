#------------------------------------------------------------------------------
# Target : run
#------------------------------------------------------------------------------
.PHONY: run
run: dir setup main 
	@echo "#-------------------------------------------------------------------#"
	@echo "# Main script Run                                                   #"
	@echo "#-------------------------------------------------------------------#"
ifdef x
	@cd $(RUN_DIR); \
        xterm -fa Monospace -fs 10 -bg steelblue -fg black -geometry 120x15 -T "[NDM_GEN] $(RUN_TAG)" -e "./$(RUN).run.csh" &
else
	@cd $(RUN_DIR); ./$(RUN).run.csh;
endif

#------------------------------------------------------------------------------
# Target : clean
#------------------------------------------------------------------------------
.PHONY : clean
clean :
	@echo ".PHONY : clean --> Delete all other filse except makefile"
	@find . -maxdepth 1 -type d ! -name "makefile" ! -name "con" ! -name "." -exec rm -rf {} \;
