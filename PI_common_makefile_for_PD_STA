set TECH                "$(TECH)"
set PROCESS             "$(PROCESS)"
set DEFAULT_LIB_CORNER  "$(DEFAULT_LIB_CORNER)"
set IMPL_TOOL_ENV       "$(IMPL_TOOL_ENV)"
set ABS_PRIM_VERSION    "$(ABS_PRIM_VERSION)"
set LIB_DIR             "$(LIB_DIR)"
set OUTFD_DIR           "$(OUTFD_DIR)"

# from prj.config ( COMMON variable )
set COMMON_PT           "$(COMMON_PT)"
set COMMON_SDC          "$(COMMON_SDC)"
set COMMON_TCL          "$(COMMON_TCL)"
set COMMON_TCL_PROCS    "$(COMMON_TCL_PROCS)"
set COMMON_CON_VERSION  "$(COMMON_CON_VERSION)"
set COMMON_CON_DIR      "$(COMMON_CON_DIR)"


# from prj.config ( PRJ variable )
set PRJ_PT             "$(PRJ_PT)"
