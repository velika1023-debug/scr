export define__PI_TOOL_COMMON_SETUP



ifeq ($(is_flat),1)
    ifeq ($(HIER_DESIGN),NONE)
        READ_DESIGN = $(DESIGN)
    else
        READ_DESIGN = $(DESIGN) $(HIER_DESIGN)
    endif
else
    READ_DESIGN = $(DESIGN)
endif


INDB_VER            = $(shell grep " $(DESIGN)_INDB_VER "           sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')
SDC_VER             = $(shell grep " $(DESIGN)_SDC_VER "            sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')
PNR_TOOL            = $(shell grep " $(DESIGN)_PNR_TOOL "           sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')

define define__READ_DESIGN_INFO
    @for i in $(READ_DESIGN); do                                                      \
        design=$$i                                                                   ;\
        SUB_INDB_VER=$$(              grep " $${design}_INDB_VER "            sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
        SUB_NET_REVISION_SYN=$$(      grep " PRE_$${design}_REVISION_SYN "    sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
        SUB_NET_REVISION_BIST=$$(     grep " PRE_$${design}_REVISION_BIST "   sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
        SUB_NET_REVISION_SCAN=$$(     grep " PRE_$${design}_REVISION_SCAN "   sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
        SUB_NET_REVISION_PNRIN=$$(    grep " PRE_$${design}_REVISION_PNRIN "  sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
        SUB_PNR_TOOL=$$(              grep " $${design}_PNR_TOOL "            sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
        SUB_DK_TYPE=$$(               grep " $${design}_DK_TYPE "             sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
        SUB_TRACK=$$(                 grep " $${design}_TRACK "               sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
        SUB_ABS_MEM_VERSION=$$(       grep " $${design}_ABS_MEM_VERSION "     sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
        SUB_ABS_IP_VERSION=$$(        grep " $${design}_ABS_IP_VERSION "      sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')     ;\
		if [ "$(PD_TARGET)" = "sta_eco" ] || [ "$(PD_TARGET)" = "dmsa_eco" ] ; then                                                       \
            SUB_NET_REVISION_POST=$$(     grep " POST_$${design}_REVISION_PEX "   sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')  ;\
            SUB_NET_ECO_NUM=$(SRC_pex)      ;\
        elif [ "$(PD_TARGET)" = "sta_psi" ] ; then                                                                                       \
            SUB_NET_REVISION_POST=$$(     grep " POST_$${design}_REVISION_PSI "   sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')  ;\
            SUB_NET_ECO_NUM=$(SRC_psi)      ;\
        fi;                                                                           \
        echo ""                                                                      ;\
        echo "#== $$design == Information"                                           ;\
        echo "set $$design(NAME)               $$design"                         ;\
        echo "set $$design(INDB_VER)           $$SUB_INDB_VER"                   ;\
        echo "set $$design(TRACK)              $$SUB_TRACK"                      ;\
        echo "set $$design(DK_TYPE)            $$SUB_DK_TYPE"                    ;\
        echo "set $$design(ABS_MEM_VERSION)    $$SUB_ABS_MEM_VERSION"            ;\
        echo "set $$design(ABS_IP_VERSION)     $$SUB_ABS_IP_VERSION"             ;\
        echo ""                                                                  ;\
        echo "set $$design(NET_REVISION_SYN)   $$SUB_NET_REVISION_SYN"           ;\
        echo "set $$design(NET_REVISION_BIST)  $$SUB_NET_REVISION_BIST"          ;\
        echo "set $$design(NET_REVISION_SCAN)  $$SUB_NET_REVISION_SCAN"          ;\
        echo "set $$design(NET_REVISION_PNRIN) $$SUB_NET_REVISION_PNRIN"         ;\
        echo ""                                                                  ;\
        echo "set $$design(PNR_TOOL)           $$SUB_PNR_TOOL"                   ;\
        echo "set $$design(NET_REVISION_POST)  $$SUB_NET_REVISION_POST"          ;\
        echo "set $$design(NET_ECO_NUM)        $$SUB_NET_ECO_NUM"                ;\
        echo ""                                                                  ;\
    done
endef
