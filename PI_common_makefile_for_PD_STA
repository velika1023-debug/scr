else ifeq ($(filter sta_psi, $(PD_TARGET)), $(PD_TARGET))
    POST_ECO_NUM        = $(shell projconf.pl -get "POST_$(DESIGN)_STEP_PSI")
    POST_NET_REVISION   = $(shell grep " POST_$(DESIGN)_REVISION_PSI" sophia_vars.tcl | awk '{print $$3}' | sed 's/"//g')
else
    $(error <ADF_ERROR> PD_TARGET($(PD_TARGET)) is not valid value.)
endif

