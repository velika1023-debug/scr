proc banner {text} {
    set text [string toupper $text]

    set lines {}

    for {set i 0} {$i < 9} {incr i} {
        lappend lines " "
    }

    foreach char [split $text ""] {
        set pattern [get_char_pattern $char]
        for {set i 0} {$i < 9} {incr i} {
            #lset lines $i [lindex $lines $i]$[lindex $pattern $i]
            lset lines $i [lindex $lines $i][lindex $pattern $i]
        }
    }

    foreach line $lines {
        puts $line
    }
}
