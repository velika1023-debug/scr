#------------------------------------------------------------------------------
# Parsing Directory
#------------------------------------------------------------------------------

#Design parsing
ifeq ($(DESIGN),AUTO_DETECT)
DESIGN := $(shell /bin/pwd | sed -e "s/.*\/SOC\///" | sed -e "s/\/.*//")
endif

W_DIR := $(shell /bin/pwd | sed -e "s/.*\/SOC\///" | sed -e "s/.*\///")

# N1B0
TOOL_NAME = $(shell basename $(PWD))



# Date & Directory
DATE        = `date +%y%m%d_%H%M`
USER        = `whoami`
REPORT_DIR  = report
OUTPUT_DIR  = output
LOG_DIR     = log
CON_DIR     = con
RUN         = syn

# MODIFY
COMMON_TCL  = $(shell projconf.pl -get "COMMON_TCL")
include $(COMMON_TCL)/PI_common_makefile

#------------------------------------------------------------------------------
# Parsing Variable from .config
#------------------------------------------------------------------------------
COMMON_DC_PRJ_SYN 	= $(shell projconf.pl -get "PRJ_DC_SYN")

# add jmpark 240524
TOOL_VER            = $(shell projconf.pl -get "TOOL_VER_DC")
ifeq ($(shell projconf.pl -get "TOOL_VER_SPYGLASS"),NA)
	TOOL_VER_SPY_GLASS  = W-2024.09-SP2-4
else
	TOOL_VER_SPY_GLASS  = $(shell projconf.pl -get "TOOL_VER_SPYGLASS")
endif

PROJECT_ENV         = $(shell projconf.pl -get "PROJECT_ENV")

ifdef v
   TOOL_VER = $(v)
endif
#------------------------------------------------------------------------------
# NET_REVISION :
#   - pre  :  PRE_${DESIGN}_REVISION_{SYN,BIST,SCAN}
#   - post : POST_${DESIGN}_REVISION
#------------------------------------------------------------------------------
ifeq ($(indb),rtl)
	INDB_TYPE          = $(indb)
else ifeq ($(indb),ddc)
	INDB_TYPE 	  	  = $(indb)
else ifeq ($(indb),net)
	INDB_TYPE 	  	  = $(indb)
else
	INDB_TYPE          = "N/A"
endif


RPT_POSTFIX 	= $(RUN_TAG)
EXPORT_DIR 		= $(OUTFD_DIR)/$(DESIGN)/$(INDB_VER)/$(TOOL_NAME)/$(EXP_TAG)
SYN_REF_DIR     = $(COMMON_DC_PRJ_SYN)/scripts
RUN_DIR = $(CURDIR)/$(RUN_TAG)

#----------------------------------------------------------------------
# Running option
#----------------------------------------------------------------------

#- Default Setting
is_flat = 0
dcnxt = 0
mcmm = 0
spg = 0
debug = 0
read_ctl = 0
gen_elab = 0
gen_compile_rpt = 0

# 24-11-14 Add iskim1001 START
ifdef af
    AF = --AF $(af)
else
    AF =
endif
# 24-11-14 Add iskim1001 END


#- DC_CMD setting
ifeq ($(dcnxt),1)
     #TOOL_SHELL = "dcnxt_shell -64"
     TOOL_SHELL = "/misc/tool/ADT/EDA/SNPS/dcnxt_shell_sub -64bit --TV ${TOOL_VER} $(AF)"
else
     #TOOL_SHELL = "dc_shell-xg-t -64"
     TOOL_SHELL = "/misc/tool/ADT/EDA/SNPS/dc_shell_sub -64bit --TV ${TOOL_VER} $(AF) "
endif

TOOL_CMD = " $(TOOL_SHELL)  -f"

#- Indb setting
ifeq ($(filter-out  clean help export,$(MAKECMDGOALS)), $(MAKECMDGOALS))
    ifeq ($(strip $(indb)),)
    $(error <ADF-ERROR>: indb variable is not defined : make indb=<value> )
    endif
endif
#- mcmm
ifeq ($(mcmm),1)
     #TOOL_CMD = " $(TOOL_SHELL) -topo -f"
     TOOL_CMD = " $(TOOL_SHELL) -topographical_mode -f"
     USE_MCMM = true
else
     USE_MCMM = false
endif
#- spg
ifeq ($(spg),1)
     #TOOL_CMD = " $(TOOL_SHELL) -topo -f"
     TOOL_CMD = " $(TOOL_SHELL) -topographical_mode -f"
     USE_SPG = true
else
     USE_SPG = false
endif

#- gen_elab
ifeq ($(gen_elab),1)
     GEN_ELAB = true
else
     GEN_ELAB = false
endif

#- gen_compile_rpt
ifeq ($(gen_compile_rpt),1)
     GEN_COMPILE_RPT = true
else
     GEN_COMPILE_RPT = false
endif

# NET_REVISION Setting
ifeq ($(TOOL_NAME),dc_syn)
    NET_REVISION = $(SYN_NET_REVISION)
else
    NET_REVISION = $(SCAN_NET_REVISION)
endif

# RUN TAG Setting
.PHONY : tag
ifdef tag
   RUN_TAG = $(INDB_VER)_$(NET_REVISION)_$(tag)
   EXP_TAG = $(NET_REVISION)_$(tag)
else
   RUN_TAG = $(INDB_VER)_$(NET_REVISION)
   EXP_TAG = $(NET_REVISION)
endif



