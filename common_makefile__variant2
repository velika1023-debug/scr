.PHONY : export_scr
export_scr :
	@echo "making export_script under run directory to export Synthesis results later"
	@echo "#!/bin/csh -f"                                    > $(RUN_DIR)/$(RUN).export.csh
	@echo "$$EXPORT_CMD"                                    >> $(RUN_DIR)/$(RUN).export.csh
	@chmod +x  $(RUN_DIR)/$(RUN).export.csh

.PHONY : export
export: export_scr
	@echo ".PHONY : export  in progress $(EXPORT_DIR)"
	$(RUN_DIR)/$(RUN).export.csh


define EXPORT_CMD

# If OUTFD_CONFIG_UPDATE Value is set to 0, OUTFD_CONFIG_FILE is not updated.
echo "#-------------------------------#\n"
echo "Do you want to replace Gen3 version with lastest ? (yes or no) : "
set OUTFD_CONFIG_UPDATE = ($$<)
echo "#-------------------------------#\n"

#Export Directory Check & Create
echo "Copying $(DESIGN) synthesis results into $(EXPORT_DIR) " > export.log
if ( ! -d $(EXPORT_DIR) ) then
	mkdir -vp $(EXPORT_DIR) >> export.log

	set WS_COFIG_FILE        = "$(PROJECT_ENV)/DESIGN/$(DESIGN).config"
	set OUTFD_CONFIG_FILE    = "$(OUTFD_DIR)/CONFIG/PI/$(DESIGN).config"

	if ( "$$OUTFD_CONFIG_UPDATE" == "yes" ) then
		if ( ! -e  $$OUTFD_CONFIG_FILE ) then
			echo "<INFO> : == Design.config Copy (W/S --> OUTFD) =="
			echo "	Design.config file does not exist."
			echo "	Copy the config file that currently exists in WorkSpace."
			umask 002 && mkdir -p `dirname $$OUTFD_CONFIG_FILE` ;# The umask setting is temporarily set to 002.
			cp -rf $$WS_COFIG_FILE $$OUTFD_CONFIG_FILE
		else
			echo "<INFO> : == Design.config modify ( In OUTFD ) =="
			echo "	Design.config file exists."
			echo "	Update the outfed_config file with the currently set information."
			sed -i "s/^PRE_$(DESIGN)_REVISION_SYN\s.*/PRE_$(DESIGN)_REVISION_SYN  $(EXP_TAG)/g" $${OUTFD_CONFIG_FILE}
		endif

		# Gen3 Latest Link path
		if (-e $(OUTFD_DIR)/$(DESIGN)/$(INDB_VER)/$(TOOL_NAME)/latest) then
			rm  $(OUTFD_DIR)/$(DESIGN)/$(INDB_VER)/$(TOOL_NAME)/latest
		endif

		echo "<INFO> : == Latest link modify ( In OUTFD ) =="
		ln -sf $(EXP_TAG) $(OUTFD_DIR)/$(DESIGN)/$(INDB_VER)/$(TOOL_NAME)/latest
	else
		echo "<INFO> : == Neither the CONFIG nor the latest link will be updated for Gen3.  =="
		echo "<INFO> : == Neither the CONFIG nor the latest link will be updated for Gen3.  =="
		echo "<INFO> : == Neither the CONFIG nor the latest link will be updated for Gen3.  =="
		echo "<INFO> : == Neither the CONFIG nor the latest link will be updated for Gen3.  =="
	endif

	echo "exported_by_$(USER) from: $(RUN_DIR)" >> $(EXPORT_DIR)/EXPORT.INFO

	#Directory Copy
	cp -vrf $(RUN_DIR)/$(LOG_DIR)                      $(EXPORT_DIR) >> export.log
	cp -vrf $(RUN_DIR)/$(REPORT_DIR)                   $(EXPORT_DIR) >> export.log
	cp -vrf $(RUN_DIR)/$(OUTPUT_DIR)                   $(EXPORT_DIR) >> export.log
	cp -vrf $(RUN_DIR)/$(CON_DIR)                      $(EXPORT_DIR) >> export.log
	cp -vf  $(RUN_DIR)/$(RPT_POSTFIX).$(RUN).info.rpt  $(EXPORT_DIR) >> export.log
	ln -svf  $(RUN_DIR)   $(EXPORT_DIR)                              >> export.log

	# Gen3 Report Link
	if ( ! -d $(EXPORT_DIR)/to_ADF ) then
		mkdir -vp $(EXPORT_DIR)/to_ADF >> export.log
	endif

	set Gen3_list = " \
	$(EXPORT_DIR)/report/$(DESIGN).compile.unmapped.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).final.area.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).final.clock_gating.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).final.global_timing.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).final.mbit.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).final.no_clock.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).final.power.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).latches.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).include_lockup_latches.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).vth.ratio.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).check_mv_design.postsynth.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).check_mv_design.presynth.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).final.user_dont_touch.rpt \
	$(EXPORT_DIR)/report/$(DESIGN).final.user_dont_use.rpt \
	$(EXPORT_DIR)/report/runtime.log \
	$(EXPORT_DIR)/log/$(DESIGN).syn.log \
	$(EXPORT_DIR)/log/$(DESIGN).syn_OPT_info.log \
	$(EXPORT_DIR)/$(RPT_POSTFIX).$(RUN).info.rpt \
	"

	foreach Gen3_file ($$Gen3_list)
	    if ( -f $$Gen3_file) then
	        ln -s $$Gen3_file $(EXPORT_DIR)/to_ADF/ >> export.log
		else
			echo "Export file : $$Gen3_file is NOT exist" >> export.log
	    endif
	end
	set Gen3_file = (`ls $(EXPORT_DIR)/log/$(DESIGN).read_constraint*.log`)
	if ($$#Gen3_file > 0) then
		foreach tt ($$Gen3_file)
			ln -s $$tt $(EXPORT_DIR)/to_ADF/ >> export.log
		end
	else
		echo "Export file : read_constraint is NOT exist" >> export.log
	endif

	echo "Export Done to $(EXPORT_DIR)"
	touch export.$(DESIGN).$(RUN).done
	chmod -R 775 $(EXPORT_DIR)
	touch $(EXPORT_DIR)/export.done

	echo "#INFO : Exporting Finised" >> export.log
else
	"#INFO : $(EXPORT_DIR) Directory already exist. Check and export again"
endif

endef
export EXPORT_CMD



